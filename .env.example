# ── Slack ────────────────────────────────────────────────────────────────────
# Bot OAuth Token from api.slack.com/apps (starts with xoxb-)
# Used for @mention scanning in MONITORED_CHANNELS.
SLACK_BOT_TOKEN=xoxb-your-token-here

# OPTIONAL — User OAuth Token (starts with xoxp-) used to scan DMs sent TO YOU.
# A bot token CANNOT see your personal DMs, only DMs sent to the bot itself.
# In your Slack app → "OAuth & Permissions", add these User Token Scopes:
#   im:history, im:read, mpim:history, users:read
# Then reinstall the app and copy the User OAuth Token.
# Leave blank to disable DM monitoring (mentions still work).
SLACK_USER_TOKEN=xoxp-your-user-token-here

# Your personal Slack User ID (click profile → More → Copy member ID)
MY_SLACK_USER_ID=U0123ABCDEF

# Comma-separated Slack User IDs whose DMs should trigger alerts
MONITORED_PEOPLE=U0AAA1,U0BBB2,U0CCC3

# Comma-separated Slack Channel IDs to watch for @mentions
MONITORED_CHANNELS=C0AAA1,C0BBB2,C0CCC3

# ── Twilio ────────────────────────────────────────────────────────────────────
# From console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone number (WhatsApp sandbox: +14155238886)
TWILIO_FROM_NUMBER=+14155238886

# ── Your contact info ─────────────────────────────────────────────────────────
# WhatsApp number with country code
YOUR_WHATSAPP_NUMBER=+201012345678
# Phone number to call (can be same as WhatsApp)
YOUR_PHONE_NUMBER=+201012345678

# ── Optional settings (defaults shown) ───────────────────────────────────────
REPLY_TIMEOUT_MINUTES=5
LOOKBACK_MINUTES=60
SEND_WHATSAPP=true
SEND_CALL=true
# Max characters of the original Slack message to include in WhatsApp body
MAX_TEXT_CHARS=600
